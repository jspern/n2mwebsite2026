---
export const prerender = true;
import PageLayout from '../../layouts/PageLayout.astro';
import ServiceCard from '../../components/services/ServiceCard.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import HomeCTA from '../../components/home/HomeCTA.astro';
import { getCollection } from 'astro:content';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---

<PageLayout
  title="Services"
  description="N2M Technology offers complete IT environment management — managed IT, cybersecurity, cloud solutions, infrastructure design, building security, and VoIP. One partner for everything."
>
  <!-- Page Hero -->
  <div class="page-hero">
    <div class="page-hero-dot-grid" aria-hidden="true"></div>
    <div class="page-hero-inner">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Services</span>
      </nav>
      <span class="page-eyebrow">What We Do</span>
      <h1 class="page-title">Complete IT environment ownership</h1>
      <p class="page-subtext">
        We don't offer a menu of disconnected products. N2M takes full ownership
        of your technology environment — physical and digital — so nothing is fragmented,
        unmanaged, or at risk.
      </p>
    </div>
  </div>

  <!-- Services Grid -->
  <section class="services-body">
    <div class="services-body-inner">
      <div class="services-grid">
        {services.map((service, i) => (
          <div class={`reveal reveal-delay-${Math.min(i + 1, 5)}`}>
            <ServiceCard
              title={service.data.title}
              summary={service.data.summary}
              slug={service.data.slug}
              icon={service.data.icon}
            />
          </div>
        ))}
      </div>

      <div class="services-philosophy reveal">
        <div class="philosophy-card">
          <h2 class="philosophy-title">The One IT philosophy</h2>
          <p class="philosophy-text">
            Every service N2M offers exists to strengthen your IT environment — not just add
            another line item. Managed IT, cybersecurity, cabling, physical security, cloud,
            and communications all connect under one roof, one standard, and one point of
            accountability. That's what makes us different.
          </p>
          <a href="/about" class="philosophy-link">
            Learn about our approach
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <HomeCTA />
</PageLayout>

<style>
  /* Page Hero */
  .page-hero {
    background: var(--color-navy);
    padding: 4rem 1.5rem 4.5rem;
    position: relative;
    overflow: hidden;
  }

  .page-hero-dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0, 157, 219, 0.1) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .page-hero-inner {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
    max-width: 800px;
    margin: 0 auto;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.4);
    margin-bottom: 2rem;
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.15s;
  }

  .breadcrumb a:hover { color: var(--color-accent); }

  .page-eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 800;
    color: white;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .page-subtext {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.7;
    max-width: 52ch;
  }

  /* Services section */
  .services-body {
    padding: var(--section-padding) 1.5rem;
    background: var(--color-white);
  }

  .services-body-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  /* Philosophy card */
  .philosophy-card {
    background: #f0f7fb;
    border: 1px solid rgba(0, 157, 219, 0.2);
    border-radius: 14px;
    padding: 2.5rem 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .philosophy-title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-navy);
  }

  .philosophy-text {
    font-size: 1rem;
    color: var(--color-mist);
    line-height: 1.7;
  }

  .philosophy-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: gap 0.2s;
  }

  .philosophy-link:hover { gap: 0.625rem; }

  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .services-grid { grid-template-columns: 1fr; }
    .philosophy-card { padding: 2rem 1.5rem; }
  }
</style>
