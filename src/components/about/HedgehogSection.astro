---
---

<section class="hedgehog-section">
  <div class="hedgehog-inner">
    <div class="hedgehog-content reveal">
      <span class="hedgehog-eyebrow">Our Philosophy</span>
      <h2 class="hedgehog-title">One IT environment.<br />Owned completely.</h2>
      <p class="hedgehog-text">
        N2M exists to own, secure, and evolve the complete IT environment for our clients —
        physical and digital — so nothing is fragmented, unmanaged, or at risk.
      </p>
      <p class="hedgehog-text">
        This isn't a list of services. It's a commitment: when you work with N2M,
        you have one partner responsible for every layer of your technology —
        from the cables in your walls to your cloud infrastructure to the locks on your doors.
      </p>

      <div class="hedgehog-pillars">
        <div class="hedgehog-pillar">
          <span class="pillar-number">01</span>
          <div>
            <h3 class="pillar-title">One Partner</h3>
            <p class="pillar-text">One company owns the outcome. No finger-pointing between vendors.</p>
          </div>
        </div>
        <div class="hedgehog-pillar">
          <span class="pillar-number">02</span>
          <div>
            <h3 class="pillar-title">One Standard</h3>
            <p class="pillar-text">Every client gets the same level of rigor, documentation, and care.</p>
          </div>
        </div>
        <div class="hedgehog-pillar">
          <span class="pillar-number">03</span>
          <div>
            <h3 class="pillar-title">One Call</h3>
            <p class="pillar-text">When something needs attention, there's one number to call. That's us.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- SVG Diagram -->
    <div class="hedgehog-diagram reveal reveal-delay-2" aria-label="N2M environment ownership diagram">
      <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" class="hedgehog-svg" role="img" aria-label="Concentric circles showing N2M at center, surrounded by services">
        <!-- Outer ring -->
        <circle cx="200" cy="200" r="185" fill="none" stroke="rgba(0,157,219,0.08)" stroke-width="1"/>
        <circle cx="200" cy="200" r="150" fill="none" stroke="rgba(0,157,219,0.12)" stroke-width="1"/>
        <circle cx="200" cy="200" r="115" fill="none" stroke="rgba(0,157,219,0.18)" stroke-width="1"/>
        <circle cx="200" cy="200" r="80" fill="rgba(0,157,219,0.06)" stroke="rgba(0,157,219,0.25)" stroke-width="1.5"/>
        <!-- Center -->
        <circle cx="200" cy="200" r="50" fill="var(--color-navy)" stroke="none"/>
        <text x="200" y="194" text-anchor="middle" fill="#009DDB" font-family="system-ui,sans-serif" font-weight="800" font-size="18">n2m</text>
        <text x="200" y="211" text-anchor="middle" fill="rgba(255,255,255,0.5)" font-family="system-ui,sans-serif" font-size="7.5" letter-spacing="1">TECHNOLOGY</text>

        <!-- Service labels at compass points -->
        <!-- Top -->
        <text x="200" y="48" text-anchor="middle" fill="var(--color-ink)" font-family="system-ui,sans-serif" font-size="11" font-weight="600">Managed IT</text>
        <line x1="200" y1="53" x2="200" y2="115" stroke="rgba(0,157,219,0.3)" stroke-width="1" stroke-dasharray="3 3"/>

        <!-- Right -->
        <text x="360" y="175" text-anchor="start" fill="var(--color-ink)" font-family="system-ui,sans-serif" font-size="11" font-weight="600">Cloud</text>
        <text x="360" y="189" text-anchor="start" fill="var(--color-ink)" font-family="system-ui,sans-serif" font-size="11" font-weight="600">Solutions</text>
        <line x1="354" y1="181" x2="282" y2="200" stroke="rgba(0,157,219,0.3)" stroke-width="1" stroke-dasharray="3 3"/>

        <!-- Bottom-right -->
        <text x="305" y="330" text-anchor="middle" fill="var(--color-ink)" font-family="system-ui,sans-serif" font-size="11" font-weight="600">Building</text>
        <text x="305" y="344" text-anchor="middle" fill="var(--color-ink)" font-family="system-ui,sans-serif" font-size="11" font-weight="600">Security</text>
        <line x1="298" y1="322" x2="240" y2="267" stroke="rgba(0,157,219,0.3)" stroke-width="1" stroke-dasharray="3 3"/>

        <!-- Bottom-left -->
        <text x="95" y="330" text-anchor="middle" fill="var(--color-ink)" font-family="system-ui,sans-serif" font-size="11" font-weight="600">VoIP</text>
        <text x="95" y="344" text-anchor="middle" fill="var(--color-ink)" font-family="system-ui,sans-serif" font-size="11" font-weight="600">Phones</text>
        <line x1="100" y1="322" x2="161" y2="267" stroke="rgba(0,157,219,0.3)" stroke-width="1" stroke-dasharray="3 3"/>

        <!-- Left -->
        <text x="24" y="175" text-anchor="end" fill="var(--color-ink)" font-family="system-ui,sans-serif" font-size="11" font-weight="600">Infra</text>
        <text x="36" y="189" text-anchor="end" fill="var(--color-ink)" font-family="system-ui,sans-serif" font-size="11" font-weight="600">Design</text>
        <line x1="40" y1="181" x2="118" y2="200" stroke="rgba(0,157,219,0.3)" stroke-width="1" stroke-dasharray="3 3"/>

        <!-- Top area - Cybersecurity -->
        <text x="200" y="358" text-anchor="middle" fill="var(--color-ink)" font-family="system-ui,sans-serif" font-size="11" font-weight="600">Cybersecurity</text>
        <line x1="200" y1="350" x2="200" y2="285" stroke="rgba(0,157,219,0.3)" stroke-width="1" stroke-dasharray="3 3"/>
      </svg>
    </div>
  </div>
</section>

<style>
  .hedgehog-section {
    padding: var(--section-padding) 1.5rem;
    background: var(--color-white);
    border-bottom: 1px solid var(--color-border);
  }

  .hedgehog-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .hedgehog-eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 0.875rem;
  }

  .hedgehog-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 800;
    color: var(--color-navy);
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .hedgehog-text {
    font-size: 1.0625rem;
    color: var(--color-mist);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .hedgehog-pillars {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .hedgehog-pillar {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .pillar-number {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    padding-top: 2px;
    flex-shrink: 0;
    width: 2rem;
  }

  .pillar-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 0.25rem;
  }

  .pillar-text {
    font-size: 0.9375rem;
    color: var(--color-mist);
    line-height: 1.55;
  }

  /* Diagram */
  .hedgehog-diagram {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hedgehog-svg {
    width: 100%;
    max-width: 400px;
    height: auto;
  }

  @media (max-width: 1024px) {
    .hedgehog-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hedgehog-diagram {
      order: -1;
    }

    .hedgehog-svg {
      max-width: 320px;
    }
  }
</style>
