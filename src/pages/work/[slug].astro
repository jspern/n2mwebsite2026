---
import PageLayout from '../../layouts/PageLayout.astro';
import HomeCTA from '../../components/home/HomeCTA.astro';
import { getCollection, render } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const workItems = await getCollection('work');
  return workItems.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---

<PageLayout
  title={item.data.title}
  description={item.data.summary}
>
  <!-- Hero -->
  <div class="work-detail-hero">
    <div class="dot-grid" aria-hidden="true"></div>
    <div class="work-detail-inner">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/work">Our Work</a>
        <span>/</span>
        <span aria-current="page">{item.data.title}</span>
      </nav>

      <span class="detail-industry">{item.data.industry}</span>
      <h1 class="detail-title">{item.data.title}</h1>
      <p class="detail-client">{item.data.client}</p>
      <div class="detail-services">
        {item.data.services.map((s) => (
          <span class="detail-service-tag">{s}</span>
        ))}
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="work-detail-body">
    <div class="work-detail-body-inner">
      <div class="prose">
        <Content />
      </div>
      <div class="work-detail-back">
        <a href="/work" class="back-link">← Back to Our Work</a>
        <a href="/contact" class="back-cta">Start a Project With Us</a>
      </div>
    </div>
  </div>

  <HomeCTA />
</PageLayout>

<style>
  .work-detail-hero {
    background: var(--color-navy);
    padding: 4rem 1.5rem 4.5rem;
    position: relative;
    overflow: hidden;
  }

  .dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0, 157, 219, 0.1) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .work-detail-inner {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.4);
    margin-bottom: 2rem;
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.15s;
  }

  .breadcrumb a:hover { color: var(--color-accent); }

  .detail-industry {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .detail-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 800;
    color: white;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .detail-client {
    font-size: 1rem;
    color: rgba(255,255,255,0.55);
    margin-bottom: 1.25rem;
  }

  .detail-services {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .detail-service-tag {
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgba(255,255,255,0.8);
    background: rgba(0, 157, 219, 0.2);
    padding: 0.3rem 0.75rem;
    border-radius: 20px;
    border: 1px solid rgba(0, 157, 219, 0.3);
  }

  .work-detail-body {
    padding: 4rem 1.5rem 5rem;
    background: var(--color-white);
  }

  .work-detail-body-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .prose {
    color: var(--color-ink);
    line-height: 1.75;
    font-size: 1.0625rem;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-top: 2.5rem;
    margin-bottom: 0.875rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .work-detail-back {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    flex-wrap: wrap;
    gap: 1rem;
  }

  .back-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-mist);
    text-decoration: none;
    transition: color 0.15s;
  }

  .back-link:hover { color: var(--color-accent); }

  .back-cta {
    background: var(--color-accent);
    color: white;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.6875rem 1.375rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .back-cta:hover { background: var(--color-accent-hover); }
</style>
