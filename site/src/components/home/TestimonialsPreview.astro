---
import SectionHeading from '@components/ui/SectionHeading.astro';
import { testimonials } from '@data/testimonials';

const featured = testimonials.filter((t) => t.featured);
---

<section class="testimonials-section">
  <div class="testimonials-inner">
    <div class="reveal">
      <SectionHeading
        eyebrow="Client Results"
        heading="What our clients say"
        subtext="Businesses across Metro Detroit trust N2M Technology to keep their IT running — proactively, reliably, and without drama."
        align="center"
      />
    </div>

    <div class="testimonials-grid">
      {featured.map((t, i) => (
        <blockquote class={`testimonial-card reveal reveal-delay-${i + 1}`}>
          <div class="testimonial-quote-mark" aria-hidden="true">&ldquo;</div>
          <p class="testimonial-text">{t.quote}</p>
          <footer class="testimonial-footer">
            <span class="testimonial-name">{t.name}</span>
            {t.industry && (
              <span class="testimonial-industry">{t.industry}</span>
            )}
          </footer>
        </blockquote>
      ))}
    </div>

    <div class="testimonials-cta reveal">
      <a href="/about#testimonials" class="testimonials-link">
        Read more client stories
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    padding: var(--section-padding) 1.5rem;
    background: #f0f7fb;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .testimonials-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .testimonials-inner > .reveal:first-child {
    margin-bottom: 3rem;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .testimonial-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 2rem 2rem 1.75rem;
    margin: 0;
    position: relative;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .testimonial-card:hover {
    box-shadow: 0 8px 32px rgba(0, 157, 219, 0.1);
    transform: translateY(-2px);
  }

  .testimonial-quote-mark {
    font-family: Georgia, serif;
    font-size: 4rem;
    color: var(--color-accent);
    line-height: 0.6;
    opacity: 0.6;
    user-select: none;
  }

  .testimonial-text {
    font-size: 1rem;
    color: var(--color-ink);
    line-height: 1.7;
    flex: 1;
    margin: 0;
  }

  .testimonial-footer {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .testimonial-name {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-ink);
  }

  .testimonial-industry {
    font-size: 0.8125rem;
    color: var(--color-mist);
    background: var(--color-accent-light);
    color: var(--color-accent);
    padding: 0.2rem 0.625rem;
    border-radius: 20px;
    font-weight: 500;
  }

  .testimonials-cta {
    text-align: center;
  }

  .testimonials-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: gap 0.2s;
  }

  .testimonials-link:hover {
    gap: 0.625rem;
  }

  @media (max-width: 1024px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .testimonial-card {
      padding: 1.5rem;
    }
  }
</style>
