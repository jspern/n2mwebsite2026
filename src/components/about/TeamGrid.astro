---
import { team } from '../../data/team';
---

<section class="team-section" id="team">
  <div class="team-inner">
    <div class="team-header reveal">
      <span class="team-eyebrow">The People Behind N2M</span>
      <h2 class="team-title">Our leadership team</h2>
      <p class="team-subtext">
        Extensive IT experience, deep client relationships, and a commitment to
        doing it right — every time.
      </p>
    </div>

    <div class="team-grid">
      {team.map((member, i) => (
        <div class={`team-card reveal reveal-delay-${Math.min(i + 1, 5)}`}>
          <div class="team-photo">
            <div class="team-photo-placeholder" aria-hidden="true">
              <span class="team-initials">
                {member.name.split(' ').map(n => n[0]).join('')}
              </span>
            </div>
          </div>
          <div class="team-info">
            <h3 class="team-name">{member.name}</h3>
            <span class="team-title-role">{member.title}</span>
            <p class="team-bio">{member.bio}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .team-section {
    padding: var(--section-padding) 1.5rem;
    background: var(--color-white);
  }

  .team-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .team-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3.5rem;
  }

  .team-eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .team-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 800;
    color: var(--color-navy);
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .team-subtext {
    font-size: 1.0625rem;
    color: var(--color-mist);
    line-height: 1.7;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.5rem;
  }

  .team-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }

  .team-photo {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 16px;
    overflow: hidden;
    background: var(--color-accent-light);
    border: 1px solid rgba(0, 157, 219, 0.2);
  }

  .team-photo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-accent-light), rgba(0, 157, 219, 0.15));
  }

  .team-initials {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.02em;
  }

  .team-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1.2;
  }

  .team-title-role {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .team-bio {
    font-size: 0.875rem;
    color: var(--color-mist);
    line-height: 1.6;
  }

  @media (max-width: 1200px) {
    .team-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .team-grid {
      grid-template-columns: 1fr;
      max-width: 300px;
      margin: 0 auto;
    }
  }
</style>
