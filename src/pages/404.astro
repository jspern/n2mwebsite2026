---
import PageLayout from '../layouts/PageLayout.astro';

export const prerender = true;
---

<PageLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist. Return to N2M Technology's homepage."
>
  <div class="error-page">
    <div class="error-dot-grid" aria-hidden="true"></div>
    <div class="error-inner">
      <span class="error-code">404</span>
      <h1 class="error-title">Page not found</h1>
      <p class="error-text">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="error-actions">
        <a href="/" class="error-btn-primary">Go to Homepage</a>
        <a href="/contact" class="error-btn-secondary">Contact Us</a>
      </div>
    </div>
  </div>
</PageLayout>

<style>
  .error-page {
    min-height: calc(100vh - 72px);
    background: var(--color-navy);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .error-dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0, 157, 219, 0.1) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .error-inner {
    position: relative;
    max-width: 500px;
  }

  .error-code {
    display: block;
    font-family: var(--font-display);
    font-size: 6rem;
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
    opacity: 0.6;
    margin-bottom: 1rem;
    letter-spacing: -0.04em;
  }

  .error-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
  }

  .error-text {
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }

  .error-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .error-btn-primary {
    background: var(--color-accent);
    color: white;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .error-btn-primary:hover { background: var(--color-accent-hover); }

  .error-btn-secondary {
    background: transparent;
    color: rgba(255,255,255,0.7);
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    border: 1.5px solid rgba(255,255,255,0.2);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }

  .error-btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
