---
import PageLayout from '../layouts/PageLayout.astro';
import HedgehogSection from '../components/about/HedgehogSection.astro';
import TeamGrid from '../components/about/TeamGrid.astro';
import HomeCTA from '../components/home/HomeCTA.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import { testimonials } from '../data/testimonials';

export const prerender = true;
---

<PageLayout
  title="About"
  description="N2M Technology has been serving Metro Detroit businesses for 25+ years. Learn about our 'One IT' philosophy, our leadership team, and why 250+ clients trust us with their complete IT environment."
>
  <!-- Hero -->
  <div class="about-hero">
    <div class="about-hero-dot-grid" aria-hidden="true"></div>
    <div class="about-hero-inner">
      <span class="about-eyebrow">About N2M Technology</span>
      <h1 class="about-title">
        25+ years of doing IT<br />the right way.
      </h1>
      <p class="about-subtext">
        Founded by Nick Oliverio with a vision to give businesses a true IT partner —
        not a vendor, not a service you call when things break, but a partner who
        owns the outcome and shows up like a member of your team.
      </p>
    </div>
  </div>

  <!-- Founder Story -->
  <section class="founder-section">
    <div class="founder-inner">
      <div class="founder-content reveal">
        <span class="founder-eyebrow">Our Story</span>
        <h2 class="founder-title">Built on a simple idea</h2>
        <p class="founder-text">
          I started N2M because I kept seeing the same problem: businesses with fragmented IT —
          multiple vendors, no clear ownership, and no one willing to take accountability when
          something went wrong. I believed there was a better way to do this.
        </p>
        <p class="founder-text">
          Over 25 years, that belief has become a clear philosophy: your business deserves one
          IT partner that owns everything — your network, your physical infrastructure, your
          security, your people's day-to-day experience with technology. No gaps.
          No finger-pointing. No surprises.
        </p>
        <p class="founder-sig">
          — Nick Oliverio, President &amp; Founder
        </p>
      </div>
      <div class="founder-stats reveal reveal-delay-2">
        <div class="founder-stat">
          <span class="founder-stat-value">25+</span>
          <span class="founder-stat-label">Years in business</span>
        </div>
        <div class="founder-stat">
          <span class="founder-stat-value">250+</span>
          <span class="founder-stat-label">Clients served</span>
        </div>
        <div class="founder-stat">
          <span class="founder-stat-value">400+</span>
          <span class="founder-stat-label">Projects completed</span>
        </div>
        <div class="founder-stat">
          <span class="founder-stat-value">98%</span>
          <span class="founder-stat-label">Customer satisfaction</span>
        </div>
      </div>
    </div>
  </section>

  <HedgehogSection />

  <TeamGrid />

  <!-- Testimonials -->
  <section class="testimonials-full" id="testimonials">
    <div class="testimonials-full-inner">
      <div class="reveal">
        <SectionHeading
          eyebrow="Client Results"
          heading="What clients say about N2M"
          align="center"
        />
      </div>

      <div class="testimonials-full-grid">
        {testimonials.filter(t => t.category === 'company').map((t, i) => (
          <blockquote class={`testimonial-card reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <div class="testimonial-quote-mark" aria-hidden="true">&ldquo;</div>
            <p class="testimonial-text">{t.quote}</p>
            <footer class="testimonial-footer">
              <span class="testimonial-name">{t.name}</span>
              {t.industry && <span class="testimonial-industry">{t.industry}</span>}
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <HomeCTA />
</PageLayout>

<style>
  /* Hero */
  .about-hero {
    background: var(--color-navy);
    padding: 5rem 1.5rem 5rem;
    position: relative;
    overflow: hidden;
  }

  .about-hero-dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0, 157, 219, 0.1) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .about-hero-inner {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
    max-width: 780px;
    margin: 0 auto;
  }

  .about-eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 0.875rem;
  }

  .about-title {
    font-family: var(--font-display);
    font-size: var(--text-display);
    font-weight: 800;
    color: white;
    line-height: 1.08;
    letter-spacing: -0.025em;
    margin-bottom: 1.5rem;
  }

  .about-subtext {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.7;
    max-width: 52ch;
  }

  /* Founder */
  .founder-section {
    padding: var(--section-padding) 1.5rem;
    background: #f0f7fb;
    border-bottom: 1px solid var(--color-border);
  }

  .founder-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 5rem;
    align-items: center;
  }

  .founder-eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 0.875rem;
  }

  .founder-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 800;
    color: var(--color-navy);
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .founder-text {
    font-size: 1.0625rem;
    color: var(--color-mist);
    line-height: 1.75;
    margin-bottom: 1.125rem;
  }

  .founder-sig {
    font-size: 1rem;
    color: var(--color-navy);
    font-weight: 600;
    font-style: italic;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  /* Stats */
  .founder-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    flex-shrink: 0;
  }

  .founder-stat {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }

  .founder-stat-value {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 0.375rem;
  }

  .founder-stat-label {
    font-size: 0.8125rem;
    color: var(--color-mist);
    font-weight: 500;
  }

  /* Testimonials */
  .testimonials-full {
    padding: var(--section-padding) 1.5rem;
    background: var(--color-white);
  }

  .testimonials-full-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .testimonials-full-inner > .reveal:first-child {
    margin-bottom: 3rem;
  }

  .testimonials-full-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .testimonial-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 2rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
  }

  .testimonial-quote-mark {
    font-family: Georgia, serif;
    font-size: 3.5rem;
    color: var(--color-accent);
    line-height: 0.6;
    opacity: 0.5;
    user-select: none;
  }

  .testimonial-text {
    font-size: 1rem;
    color: var(--color-ink);
    line-height: 1.7;
    flex: 1;
    margin: 0;
  }

  .testimonial-footer {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .testimonial-name {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-ink);
  }

  .testimonial-industry {
    font-size: 0.8125rem;
    background: var(--color-accent-light);
    color: var(--color-accent);
    padding: 0.2rem 0.625rem;
    border-radius: 20px;
    font-weight: 500;
  }

  @media (max-width: 1024px) {
    .founder-inner {
      grid-template-columns: 1fr;
    }

    .founder-stats {
      order: -1;
      width: 100%;
      max-width: 480px;
    }
  }

  @media (max-width: 768px) {
    .testimonials-full-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
