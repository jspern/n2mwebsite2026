---
const services = [
  { label: 'Managed IT Services', href: '/services/managed-it' },
  { label: 'Cybersecurity', href: '/services/cybersecurity' },
  { label: 'Cloud Solutions', href: '/services/cloud-solutions' },
  { label: 'Infrastructure Design', href: '/services/infrastructure-design' },
  { label: 'Building Security', href: '/services/building-security' },
  { label: 'VoIP Phone Services', href: '/services/voip-phone-services' },
];

const company = [
  { label: 'About', href: '/about' },
  { label: 'Our Work', href: '/work' },
  { label: 'Contact', href: '/contact' },
  { label: 'Privacy Policy', href: '/privacy' },
];
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="N2M Technology home">
          <span class="footer-logo-text">n2m</span>
          <span class="footer-logo-word">technology</span>
        </a>
        <p class="footer-tagline">Clearly Designed and Delivered</p>
        <p class="footer-mission">One IT partner. One standard. One call.</p>
        <a href="/contact" class="footer-cta">Schedule a Free Consultation</a>
      </div>

      <!-- Services -->
      <div class="footer-col">
        <h3 class="footer-col-heading">Services</h3>
        <ul class="footer-links">
          {services.map((s) => (
            <li><a href={s.href} class="footer-link">{s.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div class="footer-col">
        <h3 class="footer-col-heading">Company</h3>
        <ul class="footer-links">
          {company.map((c) => (
            <li><a href={c.href} class="footer-link">{c.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-col">
        <h3 class="footer-col-heading">Contact</h3>
        <ul class="footer-contact">
          <li>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12 19.79 19.79 0 0 1 1.95 3.25a2 2 0 0 1 1.99-2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.99 5.99l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a href="tel:+12482472626" class="footer-link">248-247-2626</a>
          </li>
          <li>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <a href="mailto:sales@n2mtech.com" class="footer-link">sales@n2mtech.com</a>
          </li>
          <li>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <a href="mailto:help@n2mtech.com" class="footer-link">help@n2mtech.com</a>
          </li>
          <li>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <address class="footer-address">
              7400 Triangle Dr., Suite B<br />
              Sterling Heights, MI
            </address>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">
        &copy; {new Date().getFullYear()} N2M Technology. All rights reserved.
      </p>
      <a href="/privacy" class="footer-link footer-privacy">Privacy Policy</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-navy);
    color: var(--color-white);
    padding: 5rem 1.5rem 2rem;
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.25fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  /* Brand */
  .footer-logo {
    display: flex;
    align-items: baseline;
    gap: 0.375rem;
    text-decoration: none;
    margin-bottom: 0.75rem;
  }

  .footer-logo-text {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .footer-logo-word {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.05em;
  }

  .footer-tagline {
    font-size: 0.8125rem;
    color: var(--color-accent);
    font-style: italic;
    margin-bottom: 0.5rem;
  }

  .footer-mission {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  .footer-cta {
    display: inline-block;
    background: var(--color-accent);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.625rem 1.25rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .footer-cta:hover {
    background: var(--color-accent-hover);
  }

  /* Columns */
  .footer-col-heading {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.4);
    margin-bottom: 1.25rem;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-link {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-link:hover {
    color: var(--color-accent);
  }

  /* Contact */
  .footer-contact {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .footer-contact li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
  }

  .footer-contact svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-accent);
  }

  .footer-address {
    font-style: normal;
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.5;
  }

  /* Bottom */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.75rem;
  }

  .footer-copyright {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.35);
  }

  .footer-privacy {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.35);
  }

  @media (max-width: 1024px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 640px) {
    .footer-top {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }
  }
</style>
