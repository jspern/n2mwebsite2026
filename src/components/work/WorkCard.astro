---
interface Props {
  title: string;
  client: string;
  industry: string;
  services: string[];
  summary: string;
  slug: string;
  featured?: boolean;
}

const { title, client, industry, services, summary, slug, featured = false } = Astro.props;
---

<a href={`/work/${slug}`} class={`work-card ${featured ? 'work-card--featured' : ''}`}>
  <div class="work-card-header">
    <div class="work-meta">
      <span class="work-industry">{industry}</span>
    </div>
    <h3 class="work-title">{title}</h3>
    <p class="work-client">{client}</p>
  </div>
  <p class="work-summary">{summary}</p>
  <div class="work-services">
    {services.map((s) => (
      <span class="work-service-tag">{s}</span>
    ))}
  </div>
  <span class="work-link">
    Read case study
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </span>
</a>

<style>
  .work-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .work-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 8px 32px rgba(0, 157, 219, 0.12);
    transform: translateY(-3px);
  }

  .work-card--featured {
    border-color: rgba(0, 157, 219, 0.3);
    background: linear-gradient(135deg, #f8fdff, #f0f8fd);
  }

  .work-meta {
    margin-bottom: 0.25rem;
  }

  .work-industry {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }

  .work-title {
    font-family: var(--font-display);
    font-size: 1.1875rem;
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1.25;
  }

  .work-client {
    font-size: 0.875rem;
    color: var(--color-mist);
  }

  .work-summary {
    font-size: 0.9375rem;
    color: var(--color-mist);
    line-height: 1.65;
    flex: 1;
  }

  .work-services {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .work-service-tag {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-ink);
    background: var(--color-accent-light);
    padding: 0.25rem 0.625rem;
    border-radius: 20px;
    border: 1px solid rgba(0, 157, 219, 0.2);
  }

  .work-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .work-link svg {
    transition: transform 0.2s;
  }

  .work-card:hover .work-link svg {
    transform: translateX(4px);
  }
</style>
