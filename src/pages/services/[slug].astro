---
import PageLayout from '../../layouts/PageLayout.astro';
import ServiceHero from '../../components/services/ServiceHero.astro';
import HomeCTA from '../../components/home/HomeCTA.astro';
import { getCollection, render } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((service) => ({
    params: { slug: service.data.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);
---

<PageLayout
  title={service.data.title}
  description={service.data.metaDescription}
>
  <ServiceHero
    title={service.data.title}
    tagline={service.data.tagline}
    icon={service.data.icon}
  />

  <div class="service-body">
    <div class="service-body-inner">
      <div class="service-content">
        <!-- Prose content from MDX -->
        <div class="prose">
          <Content />
        </div>

        <!-- What's Included -->
        <div class="service-features">
          <h2 class="service-features-title">What's included</h2>
          <ul class="service-features-list">
            {service.data.features.map((feature) => (
              <li class="service-feature-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                  <path d="m9 11 3 3L22 4"/>
                </svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Sidebar CTA -->
      <aside class="service-sidebar">
        <div class="service-sidebar-card">
          <h3 class="sidebar-title">Ready to get started?</h3>
          <p class="sidebar-text">
            Schedule a free consultation and we'll assess your current environment
            and show you how N2M can help.
          </p>
          <a href="/contact" class="sidebar-cta">Book a Free Consultation</a>
          <a href="tel:+12482472626" class="sidebar-phone">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12 19.79 19.79 0 0 1 1.95 3.25a2 2 0 0 1 1.99-2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.99 5.99l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            248-247-2626
          </a>
        </div>

        <div class="service-sidebar-nav">
          <h4 class="sidebar-nav-title">All Services</h4>
          <a href="/services" class="sidebar-nav-link">← Back to all services</a>
        </div>
      </aside>
    </div>
  </div>

  <HomeCTA />
</PageLayout>

<style>
  .service-body {
    padding: 4rem 1.5rem var(--section-padding);
    background: var(--color-white);
  }

  .service-body-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 4rem;
    align-items: start;
  }

  /* Prose */
  .prose {
    color: var(--color-ink);
    line-height: 1.75;
    font-size: 1.0625rem;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-top: 2.5rem;
    margin-bottom: 0.875rem;
    line-height: 1.2;
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.1875rem;
    font-weight: 700;
    color: var(--color-ink);
    margin-top: 2rem;
    margin-bottom: 0.625rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
    color: var(--color-ink);
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--color-navy);
  }

  .prose :global(ul) {
    padding-left: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(ul li) {
    margin-bottom: 0.5rem;
    color: var(--color-ink);
  }

  /* Features */
  .service-features {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
  }

  .service-features-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 1.25rem;
  }

  .service-features-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .service-feature-item {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.9375rem;
    color: var(--color-ink);
    line-height: 1.4;
  }

  .service-feature-item svg {
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* Sidebar */
  .service-sidebar {
    position: sticky;
    top: 96px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .service-sidebar-card {
    background: var(--color-navy);
    border-radius: 14px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .sidebar-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: white;
  }

  .sidebar-text {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
  }

  .sidebar-cta {
    display: block;
    background: var(--color-accent);
    color: white;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.75rem 1.25rem;
    border-radius: 8px;
    text-decoration: none;
    text-align: center;
    transition: background 0.15s;
  }

  .sidebar-cta:hover {
    background: var(--color-accent-hover);
  }

  .sidebar-phone {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    transition: color 0.15s;
  }

  .sidebar-phone:hover {
    color: var(--color-accent);
  }

  .service-sidebar-nav {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.25rem;
  }

  .sidebar-nav-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-mist);
    margin-bottom: 0.75rem;
  }

  .sidebar-nav-link {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
  }

  .sidebar-nav-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 1024px) {
    .service-body-inner {
      grid-template-columns: 1fr;
    }

    .service-sidebar {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .service-features-list {
      grid-template-columns: 1fr;
    }
  }
</style>
