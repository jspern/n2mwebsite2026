---
import PageLayout from '../layouts/PageLayout.astro';

export const prerender = true;
---

<PageLayout
  title="Privacy Policy"
  description="N2M Technology privacy policy — how we collect, use, and protect your information."
>
  <div class="privacy-hero">
    <div class="privacy-hero-inner">
      <h1 class="privacy-title">Privacy Policy</h1>
      <p class="privacy-updated">Last updated: April 2026</p>
    </div>
  </div>

  <div class="privacy-body">
    <div class="privacy-content">
      <p>N2M Technology ("N2M", "we", "us", or "our") is committed to protecting the privacy of our website visitors and clients. This policy describes how we collect and use information.</p>

      <h2>Information We Collect</h2>
      <p>When you contact us through this website, we collect the information you provide: your name, company, email address, phone number, and message content. We use this information solely to respond to your inquiry and provide our services.</p>

      <h2>How We Use Your Information</h2>
      <p>We use the information you provide to respond to inquiries, provide IT services, and communicate about our offerings. We do not sell, rent, or share your personal information with third parties for marketing purposes.</p>

      <h2>Cookies and Analytics</h2>
      <p>This website uses Vercel Analytics, a privacy-respecting analytics tool that does not use cookies or collect personally identifiable information. No cookie consent banner is required.</p>

      <h2>Data Security</h2>
      <p>Contact form submissions are transmitted securely over HTTPS. We take appropriate technical and organizational measures to protect your information.</p>

      <h2>Contact</h2>
      <p>If you have questions about this privacy policy, please contact us at <a href="mailto:sales@n2mtech.com">sales@n2mtech.com</a> or call <a href="tel:+12482472626">248-247-2626</a>.</p>
    </div>
  </div>
</PageLayout>

<style>
  .privacy-hero {
    background: var(--color-navy);
    padding: 4rem 1.5rem;
  }

  .privacy-hero-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .privacy-title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    color: white;
    margin-bottom: 0.5rem;
  }

  .privacy-updated {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.5);
  }

  .privacy-body {
    padding: 4rem 1.5rem 6rem;
  }

  .privacy-content {
    max-width: 800px;
    margin: 0 auto;
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-ink);
  }

  .privacy-content h2 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .privacy-content p {
    margin-bottom: 1rem;
  }

  .privacy-content a {
    color: var(--color-accent);
    text-decoration: underline;
  }
</style>
