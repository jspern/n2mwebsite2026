---
import { getCollection } from 'astro:content';
import ServiceCard from '@components/services/ServiceCard.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---

<section class="services-section">
  <div class="services-inner">
    <div class="services-header reveal">
      <SectionHeading
        eyebrow="What We Do"
        heading="Complete IT environment ownership"
        subtext="We don't hand you a list of products. We take ownership of your entire IT environment — networks, security, cloud, physical infrastructure, and communications — under one roof."
      />
      <a href="/services" class="services-view-all">
        View all services
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <div class="services-grid">
      {services.map((service, i) => (
        <div class={`reveal reveal-delay-${Math.min(i + 1, 5)}`}>
          <ServiceCard
            title={service.data.title}
            summary={service.data.summary}
            slug={service.data.slug}
            icon={service.data.icon}
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    padding: var(--section-padding) 1.5rem;
    background: var(--color-white);
  }

  .services-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .services-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .services-view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    white-space: nowrap;
    transition: gap 0.2s;
  }

  .services-view-all:hover {
    gap: 0.625rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .services-grid {
      grid-template-columns: 1fr;
    }

    .services-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
