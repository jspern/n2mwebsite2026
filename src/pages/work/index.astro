---
export const prerender = true;
import PageLayout from '../../layouts/PageLayout.astro';
import WorkCard from '../../components/work/WorkCard.astro';
import HomeCTA from '../../components/home/HomeCTA.astro';
import { getCollection } from 'astro:content';

const workItems = (await getCollection('work')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<PageLayout
  title="Our Work"
  description="See how N2M Technology has helped Metro Detroit businesses with managed IT, cybersecurity, cloud migrations, and infrastructure projects."
>
  <!-- Hero -->
  <div class="work-hero">
    <div class="work-hero-dot-grid" aria-hidden="true"></div>
    <div class="work-hero-inner">
      <span class="work-eyebrow">Our Work</span>
      <h1 class="work-title">High-quality results, consistently delivered.</h1>
      <p class="work-subtext">
        We take immense pride in the care we put into every project. Here's a glimpse
        into the work we do for clients across Metro Detroit.
      </p>
    </div>
  </div>

  <!-- Work Grid -->
  <section class="work-body">
    <div class="work-body-inner">
      <div class="work-grid">
        {workItems.map((item, i) => (
          <div class={`reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <WorkCard
              title={item.data.title}
              client={item.data.client}
              industry={item.data.industry}
              services={item.data.services}
              summary={item.data.summary}
              slug={item.id}
              featured={item.data.featured}
            />
          </div>
        ))}
      </div>

      <div class="work-cta-banner reveal">
        <p class="work-cta-text">
          Ready to be our next success story?
        </p>
        <a href="/contact" class="work-cta-btn">Schedule a Free Consultation</a>
      </div>
    </div>
  </section>

  <HomeCTA />
</PageLayout>

<style>
  .work-hero {
    background: var(--color-navy);
    padding: 4rem 1.5rem 4.5rem;
    position: relative;
    overflow: hidden;
  }

  .work-hero-dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0, 157, 219, 0.1) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .work-hero-inner {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  .work-eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 0.875rem;
  }

  .work-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 800;
    color: white;
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .work-subtext {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.7;
    max-width: 52ch;
  }

  .work-body {
    padding: var(--section-padding) 1.5rem;
    background: var(--color-white);
  }

  .work-body-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .work-cta-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    background: var(--color-navy);
    border-radius: 14px;
    padding: 2.5rem 3rem;
    flex-wrap: wrap;
  }

  .work-cta-text {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: white;
  }

  .work-cta-btn {
    background: var(--color-accent);
    color: white;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
    flex-shrink: 0;
  }

  .work-cta-btn:hover {
    background: var(--color-accent-hover);
  }

  @media (max-width: 1024px) {
    .work-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .work-grid { grid-template-columns: 1fr; }
    .work-cta-banner { flex-direction: column; align-items: flex-start; }
  }
</style>
