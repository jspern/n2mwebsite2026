---
interface Props {
  eyebrow?: string;
  heading: string;
  subtext?: string;
  align?: 'left' | 'center';
  light?: boolean;
}

const {
  eyebrow,
  heading,
  subtext,
  align = 'left',
  light = false,
} = Astro.props;
---

<div class={`section-heading section-heading--${align} ${light ? 'section-heading--light' : ''}`}>
  {eyebrow && <span class="section-eyebrow">{eyebrow}</span>}
  <h2 class="section-title">{heading}</h2>
  {subtext && <p class="section-subtext">{subtext}</p>}
</div>

<style>
  .section-heading {
    max-width: 680px;
  }

  .section-heading--center {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  .section-eyebrow {
    display: inline-block;
    font-size: var(--text-label);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .section-heading--light .section-title {
    color: white;
  }

  .section-subtext {
    font-size: var(--text-body-lg);
    color: var(--color-mist);
    line-height: 1.65;
    max-width: 56ch;
  }

  .section-heading--light .section-subtext {
    color: rgba(255,255,255,0.65);
  }
</style>
