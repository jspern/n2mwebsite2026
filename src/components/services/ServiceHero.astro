---
interface Props {
  title: string;
  tagline: string;
  icon: string;
  eyebrow?: string;
}

const { title, tagline, icon, eyebrow = 'Services' } = Astro.props;

const icons: Record<string, string> = {
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  server: `<rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>`,
  cloud: `<path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>`,
  network: `<rect x="16" y="16" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="9" y="2" width="6" height="6" rx="1"/><path d="M5 16v-3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3"/><path d="M12 12V8"/>`,
  camera: `<path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>`,
  phone: `<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12 19.79 19.79 0 0 1 1.95 3.25a2 2 0 0 1 1.99-2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.99 5.99l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>`,
};

const iconPath = icons[icon] ?? icons.server;
---

<div class="service-hero">
  <div class="service-hero-dot-grid" aria-hidden="true"></div>
  <div class="service-hero-inner">
    <nav class="service-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/services">Services</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{title}</span>
    </nav>

    <div class="service-hero-content">
      <div class="service-hero-icon" aria-hidden="true">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <Fragment set:html={iconPath} />
        </svg>
      </div>
      <span class="service-hero-eyebrow">{eyebrow}</span>
      <h1 class="service-hero-title">{title}</h1>
      <p class="service-hero-tagline">{tagline}</p>
      <a href="/contact" class="service-hero-cta">
        Talk to Our Team
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</div>

<style>
  .service-hero {
    background: var(--color-navy);
    padding: 4rem 1.5rem 4.5rem;
    position: relative;
    overflow: hidden;
  }

  .service-hero-dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0, 157, 219, 0.1) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .service-hero-inner {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
  }

  .service-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.4);
    margin-bottom: 2.5rem;
  }

  .service-breadcrumb a {
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.15s;
  }

  .service-breadcrumb a:hover {
    color: var(--color-accent);
  }

  .service-breadcrumb span[aria-current] {
    color: rgba(255,255,255,0.7);
  }

  .service-hero-content {
    max-width: 720px;
  }

  .service-hero-icon {
    width: 64px;
    height: 64px;
    border-radius: 14px;
    background: rgba(0, 157, 219, 0.15);
    border: 1px solid rgba(0, 157, 219, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .service-hero-eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .service-hero-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 800;
    color: white;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .service-hero-tagline {
    font-size: 1.1875rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.6;
    margin-bottom: 2rem;
    max-width: 48ch;
  }

  .service-hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-accent);
    color: white;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s, transform 0.15s;
    box-shadow: 0 4px 16px rgba(0, 157, 219, 0.3);
  }

  .service-hero-cta:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }
</style>
