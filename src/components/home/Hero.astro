---
---

<section class="hero">
  <!-- Dot-grid decorative background -->
  <div class="hero-dot-grid" aria-hidden="true"></div>

  <div class="hero-inner">
    <div class="hero-content">
      <span class="hero-eyebrow">
        <span class="hero-eyebrow-dot"></span>
        Managed IT Services &mdash; Sterling Heights, MI
      </span>

      <h1 class="hero-heading">
        We manage your<br />
        <em class="hero-heading-em">technology</em> so<br />
        you can manage<br />
        <em class="hero-heading-em">your business.</em>
      </h1>

      <p class="hero-subtext">
        N2M Technology owns, secures, and evolves the complete IT environment
        for your business — physical and digital. One partner. One standard. One call.
      </p>

      <div class="hero-actions">
        <a href="/contact" class="hero-btn-primary">
          Get a Free Consultation
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="/services" class="hero-btn-secondary">See What We Do</a>
      </div>

      <div class="hero-trust">
        <div class="hero-trust-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <path d="m9 11 3 3L22 4"/>
          </svg>
          25+ years of experience
        </div>
        <div class="hero-trust-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <path d="m9 11 3 3L22 4"/>
          </svg>
          250+ clients served
        </div>
        <div class="hero-trust-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <path d="m9 11 3 3L22 4"/>
          </svg>
          98% customer satisfaction
        </div>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="hero-image-frame">
        <div class="hero-image-placeholder">
          <!-- Replace with <Image> when photo is available -->
          <div class="hero-image-inner">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="rgba(0,157,219,0.4)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="8" rx="2" ry="2"/>
              <rect x="2" y="14" width="20" height="8" rx="2" ry="2"/>
              <line x1="6" y1="6" x2="6.01" y2="6"/>
              <line x1="6" y1="18" x2="6.01" y2="18"/>
            </svg>
            <p>Hero image</p>
          </div>
        </div>
        <div class="hero-image-accent"></div>
      </div>
    </div>
  </div>

  <!-- Bottom accent line -->
  <div class="hero-bottom-rule" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - 72px);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--color-white);
  }

  .hero-dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0, 157, 219, 0.07) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 5rem 1.5rem 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    flex: 1;
  }

  /* Content */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-mist);
    margin-bottom: 1.5rem;
  }

  .hero-eyebrow-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-heading {
    font-family: var(--font-display);
    font-size: var(--text-display);
    font-weight: 800;
    color: var(--color-ink);
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin-bottom: 1.75rem;
  }

  .hero-heading-em {
    font-style: normal;
    color: var(--color-accent);
  }

  .hero-subtext {
    font-size: 1.125rem;
    color: var(--color-mist);
    line-height: 1.7;
    max-width: 44ch;
    margin-bottom: 2.25rem;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .hero-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-accent);
    color: white;
    font-size: 1rem;
    font-weight: 600;
    padding: 0.875rem 1.75rem;
    border-radius: 10px;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(0, 157, 219, 0.35);
    transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
  }

  .hero-btn-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 157, 219, 0.4);
  }

  .hero-btn-secondary {
    display: inline-flex;
    align-items: center;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink);
    padding: 0.875rem 1.5rem;
    border-radius: 10px;
    border: 1.5px solid var(--color-border);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }

  .hero-btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-light);
  }

  /* Trust signals */
  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .hero-trust-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--color-mist);
  }

  .hero-trust-item svg {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  /* Visual */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-image-frame {
    position: relative;
    width: 100%;
    max-width: 540px;
    aspect-ratio: 4/3;
  }

  .hero-image-placeholder {
    width: 100%;
    height: 100%;
    border-radius: 16px;
    background: linear-gradient(135deg, #e8f4fb 0%, #d0eaf6 100%);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-image-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-mist);
    font-size: 0.875rem;
  }

  .hero-image-accent {
    position: absolute;
    bottom: -16px;
    right: -16px;
    width: 120px;
    height: 120px;
    border-radius: 12px;
    background: var(--color-accent);
    opacity: 0.12;
    z-index: -1;
  }

  .hero-bottom-rule {
    height: 1px;
    background: linear-gradient(to right, transparent, var(--color-border), transparent);
  }

  @media (max-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
      padding-top: 4rem;
    }

    .hero-visual {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .hero-heading {
      font-size: clamp(2.25rem, 9vw, 3rem);
    }

    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero-btn-primary,
    .hero-btn-secondary {
      width: 100%;
      justify-content: center;
    }
  }
</style>
