---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  ...rest
} = Astro.props;

const Tag = href ? 'a' : 'button';

const classes = [
  'btn',
  `btn--${variant}`,
  `btn--${size}`,
  className,
].filter(Boolean).join(' ');
---

<Tag href={href} class={classes} {...rest}>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: background 0.15s, color 0.15s, border-color 0.15s, transform 0.1s, box-shadow 0.15s;
    white-space: nowrap;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn:active {
    transform: translateY(0);
  }

  /* Variants */
  .btn--primary {
    background: var(--color-accent);
    color: white;
    box-shadow: 0 2px 8px rgba(0, 157, 219, 0.3);
  }

  .btn--primary:hover {
    background: var(--color-accent-hover);
    box-shadow: 0 4px 16px rgba(0, 157, 219, 0.4);
  }

  .btn--secondary {
    background: transparent;
    color: var(--color-accent);
    border: 1.5px solid var(--color-accent);
  }

  .btn--secondary:hover {
    background: var(--color-accent-light);
  }

  .btn--ghost {
    background: transparent;
    color: var(--color-ink);
    border: 1.5px solid var(--color-border);
  }

  .btn--ghost:hover {
    background: var(--color-border);
  }

  /* Sizes */
  .btn--sm {
    font-size: 0.8125rem;
    padding: 0.5rem 1rem;
  }

  .btn--md {
    font-size: 0.9375rem;
    padding: 0.6875rem 1.5rem;
  }

  .btn--lg {
    font-size: 1rem;
    padding: 0.875rem 2rem;
  }
</style>
